{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneGraph",
  "type": "object",
  "required": ["slide_size", "page_type", "objects"],
  "properties": {
    "slide_size": {"type":"array", "items":{"type":"number"}, "minItems":2, "maxItems":2},
    "page_type": {"type":"string"},
    "objects": {
      "type":"array",
      "items": {
        "type":"object",
        "required": ["id", "type", "bbox"],
        "properties": {
          "id": {"type":"string"},
          "type": {"enum":["text","card","image","shape","line","icon","group"]},
          "text": {"type":"string"},
          "bbox": {"type":"array", "items":{"type":"number"}, "minItems":4, "maxItems":4},
          "style": {"type":"object"},
          "children": {"type":"array"}
        }
      }
    }
  }
}
